#. type: SH
#: man/debconf-translation-manager.1:7
#, no-wrap
msgid "DESCRIPTION"
msgstr ""

#. type: Plain text
#: man/debconf-translation-manager.1:13
msgid ""
"B<debconf-translation-manager> is a GTK4/libadwaita application for managing "
"translations of Debian debconf templates. It provides a template browser, PO "
"editor with side-by-side view, BTS bug filing workflow, DDTSS integration, "
"review board with l10n.debian.org data, and translation statistics."
msgstr ""

