#. type: SH
#: man/debconf-translation-manager.1:7
#, no-wrap
msgid "DESCRIPTION"
msgstr "BESKRIVNING"

#. type: Plain text
#: man/debconf-translation-manager.1:13
msgid ""
"B<debconf-translation-manager> is a GTK4/libadwaita application for managing "
"translations of Debian debconf templates. It provides a template browser, PO "
"editor with side-by-side view, BTS bug filing workflow, DDTSS integration, "
"review board with l10n.debian.org data, and translation statistics."
msgstr ""
"B<debconf-translation-manager> är ett GTK4/libadwaita-program för hantering "
"av översättningar av Debian debconf-mallar. Det innehåller en mallbläddrare, "
"PO-redigerare med sida-vid-sida-vy, BTS-felrapporteringsflöde, DDTSS-"
"integration, granskningspanel med data från l10n.debian.org och "
"översättningsstatistik."

#. type: SH
#: man/debconf-translation-manager.1:13
#, no-wrap
msgid "OPTIONS"
msgstr "FLAGGOR"

#. type: TP
#: man/debconf-translation-manager.1:14
#, no-wrap
msgid "B<--no-gui>"
msgstr "B<--no-gui>"

#. type: Plain text
#: man/debconf-translation-manager.1:18
msgid ""
"Run in CLI mode without the graphical interface. Print translation "
"statistics and exit."
msgstr ""
"Kör i CLI-läge utan det grafiska gränssnittet. Skriv ut "
"översättningsstatistik och avsluta."

#. type: TP
#: man/debconf-translation-manager.1:18
#, no-wrap
msgid "B<--json>"
msgstr "B<--json>"

#. type: Plain text
#: man/debconf-translation-manager.1:21
msgid "Output statistics in JSON format (implies --no-gui)."
msgstr "Utdata i JSON-format (innebär --no-gui)."

#. type: TP
#: man/debconf-translation-manager.1:21
#, no-wrap
msgid "B<-q, --quiet>"
msgstr "B<-q, --quiet>"

#. type: Plain text
#: man/debconf-translation-manager.1:24
msgid "Quiet mode, minimal output (implies --no-gui)."
msgstr "Tyst läge, minimal utdata (innebär --no-gui)."

#. type: TP
#: man/debconf-translation-manager.1:24
#, no-wrap
